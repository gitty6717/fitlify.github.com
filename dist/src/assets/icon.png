<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="512" height="512">
  <!-- Background Circle -->
  <circle cx="256" cy="256" r="240" fill="#0a0a0a"/>
  
  <!-- Outer Ring -->
  <circle cx="256" cy="256" r="230" fill="none" stroke="#10b981" stroke-width="8"/>
  
  <!-- Inner Decorative Ring -->
  <circle cx="256" cy="256" r="200" fill="none" stroke="#10b981" stroke-width="2" opacity="0.3"/>
  
  <!-- Dumbbell Icon - Left Weight -->
  <rect x="100" y="190" width="60" height="132" rx="12" fill="#10b981"/>
  <rect x="110" y="170" width="40" height="172" rx="8" fill="#059669"/>
  
  <!-- Dumbbell Icon - Right Weight -->
  <rect x="352" y="190" width="60" height="132" rx="12" fill="#10b981"/>
  <rect x="362" y="170" width="40" height="172" rx="8" fill="#059669"/>
  
  <!-- Dumbbell Handle -->
  <rect x="160" y="236" width="192" height="40" rx="8" fill="#34d399"/>
  
  <!-- Center Highlight -->
  <circle cx="256" cy="256" r="30" fill="#10b981" opacity="0.2"/>
  
  <!-- F Letter (Fitlify) -->
  <path d="M220 280 L220 200 L300 200 L300 220 L240 220 L240 232 L290 232 L290 252 L240 252 L240 280 Z" fill="#ffffff"/>
  
  <!-- Lightning Bolt (Energy/Power) -->
  <path d="M320 160 L340 160 L325 190 L350 190 L310 240 L320 210 L300 210 Z" fill="#fbbf24"/>
  
  <!-- Decorative Dots -->
  <circle cx="160" cy="160" r="6" fill="#10b981" opacity="0.6"/>
  <circle cx="352" cy="160" r="6" fill="#10b981" opacity="0.6"/>
  <circle cx="160" cy="352" r="6" fill="#10b981" opacity="0.6"/>
  <circle cx="352" cy="352" r="6" fill="#10b981" opacity="0.6"/>
</svg>
